AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GROQ_API_KEY=
# Groq retires models on a schedule. If the default returns a model decommissioned
# error, check https://console.groq.com/docs/models and override GROQ_MODEL.
GROQ_MODEL=openai/gpt-oss-120b
JWT_SECRET=change-me-to-a-long-random-string
# Defaults to SQLite. For Postgres/RDS use: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./cost_detective.db
# Optional local development ports. The launcher auto-selects the next open port if needed.
BUDGETBEAGLE_BACKEND_PORT=8000
BUDGETBEAGLE_FRONTEND_PORT=5173
BUDGETBEAGLE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BUDGETBEAGLE_EC2_CPU_THRESHOLD_PERCENT=10
BUDGETBEAGLE_EC2_MIN_DATAPOINTS=24
BUDGETBEAGLE_EC2_MIN_OBSERVATION_HOURS=24
BUDGETBEAGLE_EC2_ANALYSIS_WINDOW_DAYS=14
BUDGETBEAGLE_ENABLE_COST_EXPLORER=true
# Set to true only during development to see detailed AWS error information in server logs.
# Secrets are never logged regardless of this setting.
DEBUG_AWS_ERRORS=false
PROGRESS_HISTORY_TTL_SECONDS=3600
ANALYSIS_HISTORY_RETENTION_ENABLED=false
ANALYSIS_HISTORY_MAX_RECORDS=
ANALYSIS_HISTORY_RETENTION_DAYS=
