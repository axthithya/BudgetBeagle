AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
GROQ_API_KEY=
# Groq retires models on a schedule. If the default returns a model decommissioned
# error, check https://console.groq.com/docs/models and override GROQ_MODEL.
GROQ_MODEL=openai/gpt-oss-120b
JWT_SECRET=change-me-to-a-long-random-string
# Defaults to SQLite. For Postgres/RDS use: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./cost_detective.db